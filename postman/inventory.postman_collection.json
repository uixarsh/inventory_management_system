                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/customers/{{customer_id}}"
          }
        },
        {
          "name": "Get Customer - Not Found (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 404', function() { pm.response.to.have.status(404); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/customers/00000000-0000-0000-0000-000000000000"
          }
        },
        {
          "name": "Delete Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204', function() { pm.response.to.have.status(204); });"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/customers/{{customer_id}}"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.order_id) {",
                  "    pm.collectionVariables.set('order_id', res.order_id);",
                  "}",
                  "pm.test('Status is 201', function() { pm.response.to.have.status(201); });",
                  "pm.test('total_amount is positive', function() { pm.expect(res.total_amount).to.be.above(0); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"{{customer_id}}\",\n  \"items\": [\n    {\n      \"product_id\": \"{{product_id}}\",\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Create Order - Insufficient Stock (expect 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 422', function() { pm.response.to.have.status(422); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"{{customer_id}}\",\n  \"items\": [\n    {\n      \"product_id\": \"{{product_id}}\",\n      \"quantity\": 99999\n    }\n  ]\n}"
            },
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Create Order - Invalid Customer (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 404', function() { pm.response.to.have.status(404); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"00000000-0000-0000-0000-000000000000\",\n  \"items\": [\n    {\n      \"product_id\": \"{{product_id}}\",\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Get All Orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Response is array', function() { pm.expect(pm.response.json()).to.be.an('array'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Get Order by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Has items array', function() { pm.expect(pm.response.json().items).to.be.an('array'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/{{order_id}}"
          }
        },
