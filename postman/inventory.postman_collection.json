{
  "info": {
    "name": "Inventory & Order Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "product_id",
      "value": ""
    },
    {
      "key": "customer_id",
      "value": ""
    },
    {
      "key": "order_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.product_id) {",
                  "    pm.collectionVariables.set('product_id', res.product_id);",
                  "}",
                  "pm.test('Status is 201', function() { pm.response.to.have.status(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mechanical Keyboard\",\n  \"sku\": \"KB-001\",\n  \"price\": 129.99,\n  \"quantity_in_stock\": 50\n}"
            },
            "url": "{{base_url}}/products"
          }
        },
        {
          "name": "Create Product - Duplicate SKU (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 409', function() { pm.response.to.have.status(409); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Another Keyboard\",\n  \"sku\": \"KB-001\",\n  \"price\": 99.99,\n  \"quantity_in_stock\": 10\n}"
            },
            "url": "{{base_url}}/products"
          }
        },
        {
          "name": "Create Product - Negative Price (expect 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 422', function() { pm.response.to.have.status(422); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bad Product\",\n  \"sku\": \"BAD-001\",\n  \"price\": -10.00,\n  \"quantity_in_stock\": 5\n}"
            },
            "url": "{{base_url}}/products"
          }
        },
        {
          "name": "Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Response is array', function() { pm.expect(pm.response.json()).to.be.an('array'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products"
          }
        },
        {
          "name": "Get Product by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/{{product_id}}"
          }
        },
        {
          "name": "Get Product - Not Found (expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 404', function() { pm.response.to.have.status(404); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/00000000-0000-0000-0000-000000000000"
          }
        },
        {
          "name": "Update Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Price updated', function() { pm.expect(pm.response.json().price).to.eql(149.99); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 149.99,\n  \"quantity_in_stock\": 45\n}"
            },
            "url": "{{base_url}}/products/{{product_id}}"
          }
        },
        {
          "name": "Delete Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 204', function() { pm.response.to.have.status(204); });"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/products/{{product_id}}"
          }
        }
      ]
    },
